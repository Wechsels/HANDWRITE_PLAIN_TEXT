{
  "name": "handwrite-plain-text",
  "version": "1.0.0",
  "description": "Modular handwritten-text generator with decoupled editor/preview windows",
  "author": "Yurui He (GitHub: Wechsels)",
  "license": "WNCPL-1.0",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package": "electron-vite build && electron-builder",
    "build:win": "electron-vite build && electron-builder --win"
  },
  "build": {
    "productName": "HandWrite Plain Text",
    "appId": "com.wechsels.handwrite",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/@napi-rs/canvas/**/*",
      "node_modules/@napi-rs/canvas-win32-x64-msvc/**/*",
      "node_modules/smol-toml/**/*"
    ],
    "extraResources": [
      {
        "from": "ttf_library",
        "to": "ttf_library",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@napi-rs/canvas-win32-x64-msvc/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HandWrite Plain Text"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@napi-rs/canvas": "^0.1.67",
    "smol-toml": "^1.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.1.10"
  }
}
